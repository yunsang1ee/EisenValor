          "component": "LoginControllerComponent"
        }
      },
      "mouseBindings": {}
    },
    "LobbyScene": {
      "label": "LobbyScene",
      "description": "SceneGlobal.RegisterScene<LobbyScene>(\"LobbyScene\"). Uses LobbySceneControllerComponent.",
