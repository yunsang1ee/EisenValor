  "scenes": {
    "global": {
      "label": "Global Inputs",
      "description": "SceneGlobal scene is not changed. GameFramework / DxrRenderPass inputs inherited by every active scene.",
      "bindings": {
        "Escape": {
          "action": "앱 종료",
          "category": "system",
          "note": "GameFramework::Update / DestroyWindow"
        },
        "F5": {
          "action": "Asset Hot Reload",
          "category": "debug",
          "note": "_DEBUG ResourceGlobal::CheckForReload. GameFramework shader reload placeholder also uses F5."
        },
        "F6": {
          "action": "Path Tracing 토글",
          "category": "render",
          "note": "DxrRenderPass::m_usePathTracing"
        },
        "F7": {
          "action": "Lite RT 토글",
          "category": "render",
          "note": "DxrRenderPass::m_useLiteRT"
        },
        "F8": {
          "action": "Physical Emission View 토글",
          "category": "render",
          "note": "DxrRenderPass::m_usePhysicalEmissionView"
        },
        "F9": {
          "action": "Day Environment 토글",
          "category": "render",
          "note": "DxrRenderPass::m_useDayEnvironment"
        },
        "F11": {
          "action": "Borderless Fullscreen 토글",
          "category": "system",
          "note": "SwapChain::ToggleBorderlessFullscreen"
        },
        "Enter": {
          "action": "Fullscreen 토글",
          "category": "system",
          "note": "SwapChain::ToggleFullscreen",
          "combo": [
            "Alt",
            "Enter"
          ]
        }
      },
      "mouseBindings": {}
    },
    "LoginScene": {
      "label": "LoginScene",
      "description": "SceneGlobal.RegisterScene<LoginScene>(\"LoginScene\"). Uses LoginControllerComponent.",
      "components": [
        "LoginControllerComponent"
      ],
      "bindings": {
        "KeyR": {
          "action": "테스트 로그인",
          "category": "system",
          "note": "Only compiled under APPLY_LOBBY_SERVER.",
          "component": "LoginControllerComponent"
        }
      },
      "mouseBindings": {}
    },
    "LobbyScene": {
      "label": "LobbyScene",
      "description": "SceneGlobal.RegisterScene<LobbyScene>(\"LobbyScene\"). Uses LobbySceneControllerComponent.",
      "components": [
        "LobbySceneControllerComponent"
      ],
      "bindings": {
        "F1": {
          "action": "로비 나가기",
          "category": "system",
          "note": "CL_LEAVE_GAME_LOBBY",
          "component": "LobbySceneControllerComponent"
        },
        "F2": {
          "action": "방 만들기",
          "category": "system",
          "note": "CL_MAKE_GAME_ROOM",
          "component": "LobbySceneControllerComponent"
        },
        "F3": {
          "action": "방 입장",
          "category": "system",
          "note": "CL_ENTER_GAME_ROOM roomID=1",
          "component": "LobbySceneControllerComponent"
        }
      },
      "mouseBindings": {}
    },
    "RoomScene": {
      "label": "RoomScene",
      "description": "SceneGlobal.RegisterScene<RoomScene>(\"RoomScene\"). Uses RoomSceneControllerComponent.",
      "components": [
        "RoomSceneControllerComponent"
      ],
      "bindings": {
        "F1": {
          "action": "방 나가기",
          "category": "system",
          "note": "CL_LEAVE_GAME_ROOM",
          "component": "RoomSceneControllerComponent"
        },
        "F2": {
          "action": "팀 변경",
          "category": "system",
          "note": "CL_CHANGE_TEAM",
          "component": "RoomSceneControllerComponent"
        },
        "F3": {
          "action": "준비",
          "category": "system",
          "note": "CL_READY_GAME",
          "component": "RoomSceneControllerComponent"
        },
        "F4": {
          "action": "봇 추가",
          "category": "spawn",
          "note": "CL_ADD_BOT",
          "component": "RoomSceneControllerComponent"
        },
        "KeyR": {
          "action": "게임 시작",
          "category": "system",
          "note": "CL_START_GAME",
          "component": "RoomSceneControllerComponent"
        }
      },
      "mouseBindings": {}
    },
    "SampleScene": {
      "label": "SampleScene",
      "description": "SceneGlobal.RegisterScene<SampleScene>(\"SampleScene\"). Uses map scene resource plus runtime player/UI components from packets.",
      "components": [
        "PlayerControllerComponent",
        "BattleUIControllerComponent",
        "VitalUIControllerComponent",
        "StressTestComponent registered but not instantiated by default"
      ],
      "bindings": {
        "F1": {
          "action": "마우스 Lock 토글",
          "category": "system",
          "note": "InputGlobal::ToggleMouseLock",
          "component": "PlayerControllerComponent"
        },
        "F2": {
          "action": "HP Debug",
          "category": "debug",
          "note": "VitalUIControllerComponent current/max HP log. Active only for objects that own VitalUIControllerComponent.",
          "component": "VitalUIControllerComponent"
        },
        "KeyW": {
          "action": "앞 이동",
          "category": "movement",
          "component": "PlayerControllerComponent"
        },
        "KeyA": {
          "action": "왼쪽 이동",
          "category": "movement",
          "component": "PlayerControllerComponent"
        },
        "KeyS": {
          "action": "뒤 이동",
          "category": "movement",
          "component": "PlayerControllerComponent"
        },
        "KeyD": {
          "action": "오른쪽 이동",
          "category": "movement",
          "component": "PlayerControllerComponent"
        },
        "ShiftLeft": {
          "action": "달리기",
          "category": "movement",
          "note": "VK_SHIFT",
          "component": "PlayerControllerComponent"
        },
        "ShiftRight": {
          "action": "달리기",
          "category": "movement",
          "note": "VK_SHIFT",
          "component": "PlayerControllerComponent"
        },
        "ControlLeft": {
          "action": "전투태세 토글",
          "category": "combat",
          "note": "VK_CONTROL",
          "component": "PlayerControllerComponent"
        },
        "ControlRight": {
          "action": "전투태세 토글",
          "category": "combat",
          "note": "VK_CONTROL",
          "component": "PlayerControllerComponent"
        },
        "AltLeft": {
          "action": "전투 대상 전환",
          "category": "combat",
          "note": "VK_MENU / CHANGE_CAMERA_TARGET",
          "component": "BattleUIControllerComponent"
        },
        "AltRight": {
          "action": "전투 대상 전환",
          "category": "combat",
          "note": "VK_MENU / CHANGE_CAMERA_TARGET",
          "component": "BattleUIControllerComponent"
        },
        "KeyE": {
          "action": "페인트 / 공격 캔슬",
          "category": "combat",
          "note": "Player fake packet. Restricted state requests CancelAttack before fake packet.",
          "component": "PlayerControllerComponent"
        },
        "KeyF": {
          "action": "NPC 장수 생성",
          "category": "spawn",
          "note": "CS_GEN_NPC_GENREAL_PACKET",
          "component": "PlayerControllerComponent"
        },
        "KeyG": {
          "action": "NPC 병사 생성",
          "category": "spawn",
          "note": "CS_GEN_NPC_SOLDIER_PACKET",
          "component": "PlayerControllerComponent"
        },
        "Digit1": {
          "action": "아군기지 이동",
          "category": "waypoint",
          "component": "PlayerControllerComponent"
        },
        "Digit2": {
          "action": "적군기지 이동",
          "category": "waypoint",
          "component": "PlayerControllerComponent"
        },
        "Digit3": {
          "action": "점령지 A 이동",
          "category": "waypoint",
          "component": "PlayerControllerComponent"
        },
        "Digit4": {
          "action": "점령지 B 이동",
          "category": "waypoint",
          "component": "PlayerControllerComponent"
        },
        "Digit5": {
          "action": "회복지 이동",
          "category": "waypoint",
          "component": "PlayerControllerComponent"
        },
        "F10": {
          "action": "Debug View",
          "category": "debug"
        },
        "F7": {
          "action": "ReSTIR PT 토글",
          "category": "render"
        }
      },
      "mouseBindings": {
        "MouseLeft": {
          "action": "약공격",
          "category": "combat",
          "note": "Neutral light attack or combat directional light attack.",
          "component": "PlayerControllerComponent / BattleUIControllerComponent"
        },
        "MouseRight": {
          "action": "강공격",
          "category": "combat",
          "note": "Neutral heavy attack or combat directional heavy attack.",
          "component": "PlayerControllerComponent / BattleUIControllerComponent"
        },
        "MouseMiddle": {
          "action": "무장해제",
          "category": "combat",
          "note": "Combat directional disarm attack.",
          "component": "BattleUIControllerComponent"
        },
        "MouseLeft+MouseRight": {
          "action": "범위공격",
          "category": "combat",
          "note": "Combat directional area attack. Input buffer accepts near-simultaneous LMB/RMB.",
          "combo": [
            "MouseLeft",
            "MouseRight"
          ],
          "component": "BattleUIControllerComponent"
        }
      }
    },
    "LoadingScene": {
      "label": "LoadingScene",
      "description": "SceneGlobal.RegisterScene<LoadingScene>(\"LoadingScene\"). No scene-specific input in current code.",
