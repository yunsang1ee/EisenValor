# EisenValor EditorConfig
root = true

[*.{cpp,h}]
charset = utf-8-bom
indent_style = tab
indent_size = 4
max_line_length = 120
trim_trailing_whitespace = false

cpp_new_line_before_open_brace_namespace = true
cpp_new_line_before_open_brace_type = true
cpp_new_line_before_open_brace_function = true
cpp_new_line_before_open_brace_control_blocks = true
cpp_new_line_before_open_brace_lambda = true
cpp_new_line_before_open_brace_object_collection_array_initializers = true
cpp_new_line_before_open_brace_class = true
cpp_new_line_before_open_brace_struct = true
cpp_new_line_before_open_brace_union = true
cpp_new_line_before_open_brace_enum = true
cpp_new_line_before_open_brace_if = true
cpp_new_line_before_open_brace_else = true
cpp_new_line_before_open_brace_switch = true
cpp_new_line_before_open_brace_case = true
cpp_new_line_before_open_brace_default = true

[*.{yml,yaml}]
indent_style = space
indent_size = 2